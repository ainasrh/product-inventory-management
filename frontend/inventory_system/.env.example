# Frontend Environment Variables
# This project uses apiConfig.js instead of .env for simplicity

# If you want to use environment variables instead:
# Uncomment the line below and update apiConfig.js to use process.env.VITE_API_BASE_URL
# VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Note: For Vite, environment variables must be prefixed with VITE_
# Example: VITE_API_BASE_URL, VITE_APP_NAME, etc.
